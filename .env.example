# SkySafe Environment Variables
# Copy this file to .env and fill in your actual API keys

# AviationStack API (https://aviationstack.com)
# Free tier: 100 requests/month
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here

# AviationStack fallback API keys (comma-separated, used when primary is exhausted)
AVIATIONSTACK_FALLBACK_KEYS=key1,key2,key3

# GNews API (https://gnews.io)
# Free tier: 100 requests/day
GNEWS_API_KEY=your_gnews_api_key_here

# NewsAPI (https://newsapi.org) - Optional fallback
# Free tier: 100 requests/day
NEWSAPI_KEY=your_newsapi_key_here

# Google Gemini API (https://ai.google.dev)
# Free tier: 60 requests/minute
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Atlas (for flight data caching)
MONGODB_URI=your_mongodb_atlas_uri_here

# MariaDB (AWS RDS) - for user authentication
MARIADB_URI=your_mariadb_connection_string_here
# JWT Secret for authentication tokens
JWT_SECRET=your_jwt_secret_here
